<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_card_gold"
    android:padding="24dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VERIFYING"
        android:textColor="#C9A84C"
        android:textSize="11sp"
        android:letterSpacing="0.25"
        android:fontFamily="sans-serif-medium"
        android:layout_gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Progress container -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminate="true"
            app:trackColor="#1A1A1A"
            app:indicatorColor="#C9A84C"
            app:trackThickness="3dp"/>
    </LinearLayout>

    <!-- Status container -->
    <LinearLayout
        android:id="@+id/statusContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <TextView
            android:id="@+id/tvStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CHECKING"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center"/>

        <TextView
            android:id="@+id/tvStatusDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please wait..."
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="4dp"
            android:layout_gravity="center"/>
    </LinearLayout>

    <!-- Device info container -->
    <LinearLayout
        android:id="@+id/deviceInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_input"
        android:padding="12dp"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tvDeviceInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Device: —"
            android:textColor="#888888"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/tvAndroidInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Android: —"
            android:textColor="#888888"
            android:textSize="10sp"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvSDKInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SDK: —"
            android:textColor="#888888"
            android:textSize="10sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    <!-- Key container -->
    <LinearLayout
        android:id="@+id/keyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KEY  "
            android:textColor="#444444"
            android:textSize="10sp"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/tvKeyText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="——————"
            android:textColor="#C9A84C"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:ellipsize="end"
            android:singleLine="true"/>
    </LinearLayout>

    <!-- Success screen -->
    <LinearLayout
        android:id="@+id/successScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textColor="#00E676"
            android:textSize="32sp"
            android:layout_gravity="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VERIFIED"
            android:textColor="#00E676"
            android:textSize="13sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

    <!-- Error screen -->
    <LinearLayout
        android:id="@+id/errorScreen"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✕"
            android:textColor="#FF4444"
            android:textSize="28sp"
            android:layout_gravity="center"/>

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ERROR"
            android:textColor="#FF4444"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_gravity="center"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</LinearLayout>
