<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="#1a237e">

    <View
         android:layout_height="0dp"
         android:layout_width="0dp"
         android:background="#80000000"
         app:layout_constraintTop_toTopOf="parent"
         app:layout_constraintStart_toStartOf="parent"
         app:layout_constraintEnd_toEndOf="parent"
         app:layout_constraintBottom_toBottomOf="parent"
         android:id="@+id/overlay" />

    <androidx.cardview.widget.CardView
         android:layout_height="320dp"
         android:layout_width="260dp"
         app:layout_constraintTop_toTopOf="parent"
         app:layout_constraintStart_toStartOf="parent"
         app:cardElevation="20dp"
         app:cardBackgroundColor="#E6FFFFFF"
         app:layout_constraintEnd_toEndOf="parent"
         app:layout_constraintBottom_toBottomOf="parent"
         app:cardCornerRadius="25dp"
         android:id="@+id/cv_download">

        <androidx.constraintlayout.widget.ConstraintLayout
             android:layout_height="match_parent"
             android:layout_width="match_parent"
             android:padding="25dp">

            <FrameLayout
                 android:layout_height="70dp"
                 android:layout_width="70dp"
                 app:layout_constraintTop_toTopOf="parent"
                 app:layout_constraintStart_toStartOf="parent"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:id="@+id/icon_container">

                <ImageView
                     android:layout_height="60dp"
                     android:layout_width="60dp"
                     android:src="@drawable/ic_launcher"
                     android:scaleType="centerInside"
                     android:adjustViewBounds="true"
                     android:id="@+id/app_icon"
                     android:layout_gravity="center" />

            </FrameLayout>

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:gravity="center"
                 app:layout_constraintStart_toStartOf="parent"
                 android:textSize="22sp"
                 android:fontFamily="sans-serif-medium"
                 android:textColor="#000000"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:layout_marginTop="18dp"
                 app:layout_constraintTop_toBottomOf="@id/icon_container"
                 android:id="@+id/game_name"
                 android:text="bgmi Update" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:gravity="center"
                 app:layout_constraintStart_toStartOf="parent"
                 android:textSize="12sp"
                 android:textColor="#666666"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:layout_marginTop="6dp"
                 app:layout_constraintTop_toBottomOf="@id/game_name"
                 android:id="@+id/package_info"
                 android:text="Downloading latest files" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:gravity="center"
                 app:layout_constraintStart_toStartOf="parent"
                 android:textSize="16sp"
                 android:fontFamily="sans-serif-medium"
                 android:textColor="#333333"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:layout_marginTop="22dp"
                 app:layout_constraintTop_toBottomOf="@id/package_info"
                 android:id="@+id/loading_text"
                 android:text="Downloading..." />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                 android:layout_height="55dp"
                 android:layout_width="55dp"
                 app:trackColor="#E0E0E0"
                 app:layout_constraintStart_toStartOf="parent"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:layout_marginTop="15dp"
                 app:layout_constraintTop_toBottomOf="@id/loading_text"
                 android:id="@+id/progress_indicator"
                 app:indicatorColor="#4CAF50" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:gravity="center"
                 app:layout_constraintStart_toStartOf="parent"
                 android:textSize="14sp"
                 android:fontFamily="sans-serif-bold"
                 android:textColor="#4CAF50"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:layout_marginTop="8dp"
                 app:layout_constraintTop_toBottomOf="@id/progress_indicator"
                 android:id="@+id/progress_percent"
                 android:text="0%" />

            <TextView
                 android:layout_height="wrap_content"
                 android:layout_width="0dp"
                 android:gravity="center"
                 app:layout_constraintStart_toStartOf="parent"
                 android:textSize="12sp"
                 android:textColor="#757575"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:layout_marginTop="5dp"
                 app:layout_constraintTop_toBottomOf="@id/progress_percent"
                 android:id="@+id/status_message"
                 android:text="Initializing..." />

            <com.google.android.material.button.MaterialButton
                 android:layout_height="38dp"
                 android:layout_width="100dp"
                 android:visibility="gone"
                 app:backgroundTint="#FF5252"
                 android:textSize="12sp"
                 android:textColor="#FFFFFF"
                 android:layout_marginTop="18dp"
                 app:layout_constraintTop_toBottomOf="@id/status_message"
                 app:layout_constraintStart_toStartOf="parent"
                 app:cornerRadius="19dp"
                 android:textAllCaps="true"
                 app:layout_constraintEnd_toEndOf="parent"
                 android:id="@+id/btn_cancel"
                 android:text="CANCEL" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>