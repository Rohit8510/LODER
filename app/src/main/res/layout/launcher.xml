<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent">

    <View
        android:layout_height="0dp"
        android:layout_width="0dp"
        android:background="#80000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <androidx.cardview.widget.CardView
        android:layout_height="wrap_content"
        android:layout_width="240dp" 
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:cardElevation="15dp"
        app:cardBackgroundColor="#E6FFFFFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:cardCornerRadius="20dp"  
        android:id="@+id/cv_lauch">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:padding="16dp">  

            
            <FrameLayout
                android:layout_height="65dp" 
                android:layout_width="65dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:id="@+id/icon_container">

                <ImageView
                    android:layout_height="match_parent"
                    android:layout_width="match_parent"
                    android:visibility="visible"
                    android:src="@drawable/ic_glow"
                    android:alpha="0.25" 
                    android:id="@+id/glow_effect" />

                <ImageView
                    android:layout_height="45dp" 
                    android:layout_width="45dp"
                    android:scaleType="fitCenter"
                    android:id="@+id/app_icon"
                    android:layout_gravity="center" />

            </FrameLayout>

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="0dp"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="sans-serif-medium"
                android:textSize="18sp"
                android:textColor="#000000"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="12dp" 
                app:layout_constraintTop_toBottomOf="@+id/icon_container"
                android:id="@+id/game_name"
                android:text="Game Name"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="0dp"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="sans-serif"
                android:textSize="10sp"
                android:textColor="#666666"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="3dp"
                app:layout_constraintTop_toBottomOf="@+id/game_name"
                android:id="@+id/package_info"
                android:text="com.package.name"
                android:maxLines="1"
                android:ellipsize="middle" />

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="0dp"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="sans-serif-medium"
                android:textSize="14sp" 
                android:textColor="#333333"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="18dp"
                app:layout_constraintTop_toBottomOf="@+id/package_info"
                android:id="@+id/loading_text"
                android:text="Launching..." />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:layout_height="40dp"
                android:layout_width="40dp"
                app:trackColor="#E0E0E0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@+id/loading_text"
                android:id="@+id/progress_indicator"
                app:indicatorColor="#4CAF50" />

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="0dp"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="sans-serif-bold"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toBottomOf="@+id/progress_indicator"
                android:id="@+id/progress_percent"
                android:text="0%" />

            <TextView
                android:layout_height="wrap_content"
                android:layout_width="0dp"
                android:gravity="center"
                app:layout_constraintStart_toStartOf="parent"
                android:fontFamily="sans-serif"
                android:textSize="10sp"
                android:textColor="#757575"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="5dp"
                app:layout_constraintTop_toBottomOf="@+id/progress_percent"
                android:layout_marginBottom="10dp" 
                app:layout_constraintBottom_toBottomOf="parent"
                android:id="@+id/status_message"
                android:text="Initializing environment..."
                android:maxLines="2"
                android:ellipsize="end" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>