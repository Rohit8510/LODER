<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#AA00FF00"> <!-- Ripple effect for touch feedback -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#4CAF50"
                android:centerColor="#66BB6A"
                android:endColor="#81C784"
                android:type="linear" />
            <corners android:radius="22dp" />
            <stroke
                android:width="1dp"
                android:color="#A5D6A7" />
            <!-- Inner shadow simulation using padding or just gradient is cleaner in XML -->
        </shape>
    </item>
</ripple>
