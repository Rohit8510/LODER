<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════════
         MAIN THEME — used by all activities in manifest
         Parent: DayNight.NoActionBar (safe, widely supported)
    ══════════════════════════════════════════════════ -->
    <style name="Theme.BlackBox" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="actionMenuTextColor">@color/primary_text</item>
        <item name="materialButtonStyle">@style/Widget.BlackBox.Button</item>
        <item name="materialCardViewStyle">@style/Widget.BlackBox.CardView</item>
        <item name="textInputStyle">@style/Widget.BlackBox.TextInputLayout</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.BlackBox.MaterialAlertDialog</item>
    </style>

    <!-- Splash theme — plain dark, no title bar, no flicker -->
    <style name="WelcomeTheme" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- Premium theme alias -->
    <style name="Theme.Premium" parent="Theme.BlackBox"/>

    <!-- Translucent overlay theme (used by dialogs/overlays) -->
    <style name="Theme.Translucent" parent="Theme.MaterialComponents.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">false</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
        <item name="android:windowAnimationStyle">@style/EliteAnimation</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorAccent">@color/accent</item>
    </style>

    <!-- Toolbar overlay -->
    <style name="ToolBarColorStyle" parent="ThemeOverlay.AppCompat.ActionBar">
        <item name="actionMenuTextColor">@color/white</item>
        <item name="colorControlNormal">@color/white</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <!-- Animations -->
    <style name="EliteAnimation">
        <item name="android:windowEnterAnimation">@anim/slide_up</item>
        <item name="android:windowExitAnimation">@anim/slide_down</item>
    </style>

    <!-- Material components -->
    <style name="Widget.BlackBox.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">10dp</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/primary</item>
    </style>

    <style name="Widget.BlackBox.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/bg_card</item>
    </style>

    <style name="Widget.BlackBox.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="hintTextColor">@color/primary_light</item>
        <item name="android:textColorHint">@color/hint_color</item>
        <item name="passwordToggleTint">@color/primary</item>
        <item name="endIconTint">@color/primary</item>
    </style>

    <style name="ThemeOverlay.BlackBox.MaterialAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/primary_light</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <!-- Switch styles -->
    <style name="PKSwitch" parent="Theme.AppCompat.DayNight">
        <item name="colorControlActivated">@color/primary</item>
        <item name="colorSwitchThumbNormal">@color/secondary_text</item>
        <item name="android:colorForeground">@color/white</item>
    </style>

    <style name="PKSwitch2" parent="Theme.AppCompat.DayNight">
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorSwitchThumbNormal">@color/secondary_text</item>
        <item name="android:colorForeground">@color/white</item>
    </style>

    <!-- Shape overlays -->
    <style name="ShapeAppearanceOverlay.BlackBox.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize50Percent" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>
